{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "prompt2analytics MCP Tool Schema",
  "description": "Summary of 101 MCP tools exposed by p2a-mcp server",
  "version": "0.1.0",
  "tool_categories": {
    "data_management": {
      "count": 7,
      "tools": [
        {
          "name": "load_dataset",
          "description": "Load a dataset from CSV, JSON, or Parquet file",
          "required_params": ["path"],
          "optional_params": ["name", "delimiter", "has_header"]
        },
        {
          "name": "describe_dataset",
          "description": "Get summary statistics and schema for a loaded dataset",
          "required_params": ["dataset"]
        },
        {
          "name": "head",
          "description": "Preview first n rows of dataset",
          "required_params": ["dataset"],
          "optional_params": ["n"]
        },
        {
          "name": "tail",
          "description": "Preview last n rows of dataset",
          "required_params": ["dataset"],
          "optional_params": ["n"]
        },
        {
          "name": "sample",
          "description": "Get random sample of rows",
          "required_params": ["dataset"],
          "optional_params": ["n", "seed"]
        },
        {
          "name": "list_datasets",
          "description": "List all loaded datasets in current session"
        },
        {
          "name": "generate_dataset",
          "description": "Generate synthetic dataset with specified structure",
          "required_params": ["name", "rows", "columns"]
        }
      ]
    },
    "data_transformation": {
      "count": 19,
      "tools": [
        {
          "name": "munge_filter",
          "description": "Filter rows based on conditions",
          "required_params": ["dataset", "condition"]
        },
        {
          "name": "munge_select",
          "description": "Select specific columns",
          "required_params": ["dataset", "columns"]
        },
        {
          "name": "munge_mutate",
          "description": "Create or transform columns",
          "required_params": ["dataset", "mutations"]
        },
        {
          "name": "munge_group_by",
          "description": "Group data and aggregate",
          "required_params": ["dataset", "by", "aggregations"]
        },
        {
          "name": "munge_join",
          "description": "Join two datasets",
          "required_params": ["left", "right", "on"],
          "optional_params": ["how"]
        },
        {
          "name": "munge_pivot_longer",
          "description": "Reshape wide to long format",
          "required_params": ["dataset", "cols", "names_to", "values_to"]
        },
        {
          "name": "munge_pivot_wider",
          "description": "Reshape long to wide format",
          "required_params": ["dataset", "names_from", "values_from"]
        }
      ],
      "note": "Additional tools for sorting, renaming, distinct, slice operations"
    },
    "regression": {
      "count": 10,
      "tools": [
        {
          "name": "regression_ols",
          "description": "Ordinary Least Squares regression with optional robust/clustered SEs",
          "required_params": ["dataset", "y_var", "x_vars"],
          "optional_params": ["intercept", "cov_type", "cluster_var"]
        },
        {
          "name": "regression_wls",
          "description": "Weighted Least Squares",
          "required_params": ["dataset", "y_var", "x_vars", "weights"]
        },
        {
          "name": "regression_gls",
          "description": "Generalized Least Squares",
          "required_params": ["dataset", "y_var", "x_vars"]
        },
        {
          "name": "regression_nls",
          "description": "Nonlinear Least Squares",
          "required_params": ["dataset", "formula", "start_values"]
        },
        {
          "name": "regression_diagnostics",
          "description": "Run comprehensive diagnostics on regression",
          "required_params": ["dataset", "y_var", "x_vars"]
        }
      ],
      "common_parameters": {
        "cov_type": {
          "type": "enum",
          "values": ["standard", "hc0", "hc1", "hc2", "hc3"],
          "default": "hc1",
          "description": "Covariance estimator type"
        }
      }
    },
    "panel_data": {
      "count": 5,
      "tools": [
        {
          "name": "panel_fixed_effects",
          "description": "Within-transformation fixed effects estimator",
          "required_params": ["dataset", "y_var", "x_vars", "entity_var"],
          "optional_params": ["time_var", "cov_type", "cluster_var"]
        },
        {
          "name": "panel_random_effects",
          "description": "GLS random effects estimator",
          "required_params": ["dataset", "y_var", "x_vars", "entity_var"]
        },
        {
          "name": "panel_hdfe",
          "description": "High-dimensional fixed effects (MAP algorithm)",
          "required_params": ["dataset", "y_var", "x_vars", "fe_vars"]
        },
        {
          "name": "hausman_test",
          "description": "Hausman specification test for FE vs RE",
          "required_params": ["dataset", "y_var", "x_vars", "entity_var"]
        },
        {
          "name": "panel_feglm",
          "description": "GLM with high-dimensional fixed effects",
          "required_params": ["dataset", "y_var", "x_vars", "fe_vars", "family"]
        }
      ]
    },
    "causal_inference": {
      "count": 8,
      "tools": [
        {
          "name": "iv_2sls",
          "description": "Two-stage least squares instrumental variables",
          "required_params": ["dataset", "y_var", "endog_vars", "instruments", "exog_vars"]
        },
        {
          "name": "diff_in_diff",
          "description": "Difference-in-differences estimator",
          "required_params": ["dataset", "y_var", "treat_var", "post_var"],
          "optional_params": ["x_vars", "cluster_var"]
        },
        {
          "name": "treatment_ipw",
          "description": "Inverse probability weighting for ATE",
          "required_params": ["dataset", "y_var", "treat_var", "covariates"]
        },
        {
          "name": "treatment_aipw",
          "description": "Augmented IPW (doubly robust)",
          "required_params": ["dataset", "y_var", "treat_var", "covariates"]
        },
        {
          "name": "mediation_analysis",
          "description": "Causal mediation analysis",
          "required_params": ["dataset", "y_var", "treat_var", "mediator", "covariates"]
        },
        {
          "name": "synthetic_control",
          "description": "Synthetic control method",
          "required_params": ["dataset", "outcome", "unit_var", "time_var", "treated_unit", "pre_periods"]
        }
      ]
    },
    "discrete_choice": {
      "count": 2,
      "tools": [
        {
          "name": "logit",
          "description": "Logistic regression for binary outcomes",
          "required_params": ["dataset", "y_var", "x_vars"]
        },
        {
          "name": "probit",
          "description": "Probit regression for binary outcomes",
          "required_params": ["dataset", "y_var", "x_vars"]
        }
      ]
    },
    "time_series": {
      "count": 6,
      "tools": [
        {
          "name": "ts_arima_fit",
          "description": "Fit ARIMA model",
          "required_params": ["dataset", "y_var"],
          "optional_params": ["p", "d", "q", "seasonal"]
        },
        {
          "name": "ts_var",
          "description": "Vector autoregression",
          "required_params": ["dataset", "vars", "lags"]
        },
        {
          "name": "ts_vecm",
          "description": "Vector error correction model",
          "required_params": ["dataset", "vars", "lags", "cointegration_rank"]
        },
        {
          "name": "ts_decompose",
          "description": "Seasonal decomposition (STL/MSTL)",
          "required_params": ["dataset", "y_var"],
          "optional_params": ["period", "method"]
        },
        {
          "name": "ts_unit_root",
          "description": "Unit root tests (ADF, PP, KPSS)",
          "required_params": ["dataset", "y_var"],
          "optional_params": ["test_type", "lags"]
        },
        {
          "name": "ts_forecast",
          "description": "Generate forecasts from fitted model",
          "required_params": ["model_id", "horizon"]
        }
      ]
    },
    "statistical_tests": {
      "count": 30,
      "categories": [
        {
          "name": "comparison_tests",
          "tools": ["t_test", "paired_t_test", "welch_t_test", "wilcoxon_test", "mann_whitney_test"]
        },
        {
          "name": "anova_tests",
          "tools": ["anova_oneway", "anova_twoway", "manova", "tukey_hsd"]
        },
        {
          "name": "distribution_tests",
          "tools": ["shapiro_wilk", "kolmogorov_smirnov", "anderson_darling", "jarque_bera"]
        },
        {
          "name": "association_tests",
          "tools": ["chi_squared_test", "fisher_exact", "correlation_test"]
        },
        {
          "name": "regression_diagnostics",
          "tools": ["breusch_pagan", "durbin_watson", "vif", "reset_test"]
        }
      ]
    },
    "machine_learning": {
      "count": 7,
      "tools": [
        {
          "name": "ml_kmeans",
          "description": "K-means clustering",
          "required_params": ["dataset", "vars", "k"]
        },
        {
          "name": "ml_dbscan",
          "description": "DBSCAN clustering",
          "required_params": ["dataset", "vars", "eps", "min_samples"]
        },
        {
          "name": "ml_hierarchical",
          "description": "Hierarchical clustering",
          "required_params": ["dataset", "vars"],
          "optional_params": ["method", "n_clusters"]
        },
        {
          "name": "ml_pca",
          "description": "Principal component analysis",
          "required_params": ["dataset", "vars"],
          "optional_params": ["n_components", "scale"]
        }
      ]
    },
    "visualization": {
      "count": 7,
      "tools": [
        {
          "name": "viz_scatter",
          "description": "Scatter plot (static PNG)",
          "required_params": ["dataset", "x_var", "y_var"]
        },
        {
          "name": "viz_scatter_interactive",
          "description": "Interactive scatter plot (Plotly HTML)",
          "required_params": ["dataset", "x_var", "y_var"]
        },
        {
          "name": "viz_histogram",
          "description": "Histogram (static PNG)",
          "required_params": ["dataset", "var"]
        },
        {
          "name": "viz_line",
          "description": "Line chart for time series",
          "required_params": ["dataset", "x_var", "y_var"]
        },
        {
          "name": "viz_heatmap",
          "description": "Correlation heatmap",
          "required_params": ["dataset", "vars"]
        }
      ]
    }
  },
  "common_conventions": {
    "dataset_parameter": "All tools operating on data require a 'dataset' parameter with the loaded dataset name",
    "variable_naming": "Dependent variable is 'y_var', independent variables are 'x_vars'",
    "defaults": "Sensible defaults are provided (e.g., intercept=true, cov_type='hc1')",
    "error_handling": "Tools return structured errors with suggestions when possible"
  },
  "notes": [
    "This is a summary schema; see p2a-mcp source for complete specifications",
    "Tool count: 101 total across all categories",
    "All tools support JSON output for programmatic consumption"
  ]
}
