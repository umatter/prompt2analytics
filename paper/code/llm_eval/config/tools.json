{
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "regression_ols",
        "description": "Run Ordinary Least Squares (OLS) regression. Returns coefficients, standard errors, t-values, p-values, R-squared, and F-statistic.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string", "description": "Name of the dataset"},
            "y_col": {"type": "string", "description": "Dependent variable column"},
            "x_cols": {"type": "array", "items": {"type": "string"}, "description": "Independent variable columns"},
            "intercept": {"type": "boolean", "description": "Include intercept term"},
            "robust": {"type": "string", "enum": ["none", "hc0", "hc1", "hc2", "hc3"], "description": "Robust SE type"}
          },
          "required": ["dataset", "y_col", "x_cols"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "regression_diagnostics",
        "description": "Run comprehensive regression diagnostics. Tests include: Jarque-Bera (normality), Breusch-Pagan (heteroskedasticity), Durbin-Watson (autocorrelation), VIF (multicollinearity), and condition number.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "y_col": {"type": "string"},
            "x_cols": {"type": "array", "items": {"type": "string"}}
          },
          "required": ["dataset", "y_col", "x_cols"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "regression_clustered",
        "description": "Run OLS regression with clustered standard errors. Supports one-way (firm, state) or two-way (firm + time) clustering. Essential for panel data with correlated errors.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "y_col": {"type": "string"},
            "x_cols": {"type": "array", "items": {"type": "string"}},
            "cluster_col": {"type": "string"},
            "cluster_col2": {"type": "string"}
          },
          "required": ["dataset", "y_col", "x_cols", "cluster_col"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "regression_nls",
        "description": "Fit a nonlinear regression model using Levenberg-Marquardt algorithm. Supports common models: exponential decay/growth, Michaelis-Menten kinetics, logistic growth, power law, asymptotic.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "y_col": {"type": "string"},
            "x_col": {"type": "string"},
            "model_type": {"type": "string", "enum": ["exponential_decay", "exponential_growth", "michaelis_menten", "logistic", "power", "asymptotic"]}
          },
          "required": ["dataset", "y_col", "x_col", "model_type"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "regression_loess",
        "description": "Fit a LOESS (LOcally Estimated Scatterplot Smoothing) model for non-parametric trend estimation.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "y_col": {"type": "string"},
            "x_col": {"type": "string"},
            "span": {"type": "number"}
          },
          "required": ["dataset", "y_col", "x_col"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "panel_fixed_effects",
        "description": "Run Fixed Effects (within) panel regression. Controls for time-invariant unobserved heterogeneity. Requires panel data with entity identifiers.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "y_col": {"type": "string"},
            "x_cols": {"type": "array", "items": {"type": "string"}},
            "entity_col": {"type": "string"},
            "time_col": {"type": "string"}
          },
          "required": ["dataset", "y_col", "x_cols", "entity_col"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "panel_random_effects",
        "description": "Run Random Effects (GLS) panel regression. Assumes individual effects are uncorrelated with regressors. More efficient than FE if assumption holds.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "y_col": {"type": "string"},
            "x_cols": {"type": "array", "items": {"type": "string"}},
            "entity_col": {"type": "string"}
          },
          "required": ["dataset", "y_col", "x_cols", "entity_col"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "hausman_test",
        "description": "Run Hausman specification test to choose between Fixed Effects and Random Effects. Tests H0: RE is consistent. If p-value < 0.05, use Fixed Effects.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "y_col": {"type": "string"},
            "x_cols": {"type": "array", "items": {"type": "string"}},
            "entity_col": {"type": "string"}
          },
          "required": ["dataset", "y_col", "x_cols", "entity_col"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "panel_hdfe",
        "description": "Run High-Dimensional Fixed Effects (HDFE) regression with multiple absorbed fixed effects (e.g., firm + year + industry). Uses the Method of Alternating Projections (MAP) for efficient estimation.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "y_col": {"type": "string"},
            "x_cols": {"type": "array", "items": {"type": "string"}},
            "fe_cols": {"type": "array", "items": {"type": "string"}}
          },
          "required": ["dataset", "y_col", "x_cols", "fe_cols"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "feglm",
        "description": "Run Generalized Linear Model with high-dimensional fixed effects (FEGLM). Supports Logit, Probit, Poisson, and Gaussian families with multiple absorbed fixed effects.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "y_col": {"type": "string"},
            "x_cols": {"type": "array", "items": {"type": "string"}},
            "fe_cols": {"type": "array", "items": {"type": "string"}},
            "family": {"type": "string", "enum": ["logit", "probit", "poisson", "gaussian"]}
          },
          "required": ["dataset", "y_col", "x_cols", "fe_cols", "family"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "iv_2sls",
        "description": "Run Instrumental Variables (2SLS) regression. Use when an explanatory variable is endogenous (correlated with the error term). Requires valid instruments.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "y_col": {"type": "string"},
            "endog_cols": {"type": "array", "items": {"type": "string"}},
            "exog_cols": {"type": "array", "items": {"type": "string"}},
            "instrument_cols": {"type": "array", "items": {"type": "string"}}
          },
          "required": ["dataset", "y_col", "endog_cols", "instrument_cols"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "iv_first_stage",
        "description": "Run first-stage diagnostics to test instrument strength. Reports F-statistic (F > 10 suggests strong instruments), R-squared, and coefficient estimates.",
        "parameters": {
          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "endog_col": {"type": "string"},
            "exog_cols": {"type": "array", "items": {"type": "string"}},
            "instrument_cols": {"type": "array", "items": {"type": "string"}}
          },
          "required": ["dataset", "endog_col", "instrument_cols"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "diff_in_diff",
        "description": "Run Difference-in-Differences (DiD) estimation. Estimates causal treatment effects by comparing treated vs control groups before and after treatment.",
