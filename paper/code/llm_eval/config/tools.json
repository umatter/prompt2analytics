          "type": "object",
          "properties": {
            "dataset": {"type": "string"},
            "y_col": {"type": "string"},
            "treat_col": {"type": "string"},
            "post_col": {"type": "string"},
            "x_cols": {"type": "array", "items": {"type": "string"}}
          },
          "required": ["dataset", "y_col", "treat_col", "post_col"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "treatment_ipw",
