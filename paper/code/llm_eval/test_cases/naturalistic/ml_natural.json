      "expected_tools": ["ml_pca"],
      "acceptable_tools": ["ml_pca"],
      "dataset_context": "survey_responses: q1, q2, q3, ..., q50",
      "linguistic_features": ["domain_jargon", "specific_parameters"]
    },
    {
