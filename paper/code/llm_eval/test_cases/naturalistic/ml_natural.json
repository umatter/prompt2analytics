      "dataset_context": "survey_responses: q1, q2, q3, ..., q50",
      "linguistic_features": ["informal_register", "problem_statement"]
    },
    {
      "id": "nat_ml_006",
      "base_test_id": "ml_005",
      "prompt_type": "domain_jargon",
