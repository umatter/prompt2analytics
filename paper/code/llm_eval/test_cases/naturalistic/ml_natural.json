{
  "category": "naturalistic_ml",
  "description": "Naturalistic prompt variations for machine learning tests",
  "tests": [
    {
      "id": "nat_ml_001",
      "base_test_id": "ml_001",
      "prompt_type": "informal",
      "prompt": "group customers into like 5 segments",
      "expected_tools": ["ml_kmeans"],
      "acceptable_tools": ["ml_kmeans", "ml_hierarchical"],
      "dataset_context": "customers: spending, frequency, recency, customer_id",
      "linguistic_features": ["informal_register", "filler_words"]
    },
    {
      "id": "nat_ml_002",
      "base_test_id": "ml_001",
      "prompt_type": "domain_jargon",
      "prompt": "Perform k-means clustering with k=5 using Lloyd's algorithm",
      "expected_tools": ["ml_kmeans"],
      "acceptable_tools": ["ml_kmeans"],
      "dataset_context": "customers: spending, frequency, recency, customer_id",
      "linguistic_features": ["domain_jargon", "algorithm_reference"]
    },
    {
      "id": "nat_ml_003",
      "base_test_id": "ml_002",
      "prompt_type": "verbose",
      "prompt": "I have customer data with spending, purchase frequency, and other variables. I want to identify natural groupings or segments in my customer base without specifying the number of groups in advance. Is there a clustering method that can help with this?",
      "expected_tools": ["ml_hierarchical"],
      "acceptable_tools": ["ml_hierarchical", "ml_kmeans", "ml_dbscan"],
      "dataset_context": "customers: spending, frequency, recency, customer_id",
      "linguistic_features": ["verbose", "problem_description", "uncertainty"]
    },
    {
      "id": "nat_ml_004",
      "base_test_id": "ml_003",
      "prompt_type": "typos",
      "prompt": "pricnipal componet anlysis for dimesnion reduciton",
      "expected_tools": ["ml_pca"],
      "acceptable_tools": ["ml_pca"],
      "dataset_context": "survey_responses: q1, q2, q3, ..., q50",
      "linguistic_features": ["typos", "severe_misspellings"]
    },
    {
      "id": "nat_ml_005",
