{
  "category": "naturalistic_viz",
  "description": "Naturalistic prompt variations for visualization tests",
  "tests": [
    {
      "id": "nat_viz_001",
      "base_test_id": "viz_001",
      "prompt_type": "informal",
      "prompt": "make a histogram of the income variable",
      "expected_tools": ["viz_histogram"],
      "acceptable_tools": ["viz_histogram"],
      "dataset_context": "census: income, age, education, occupation",
      "linguistic_features": ["informal_register", "direct"]
    },
    {
      "id": "nat_viz_002",
      "base_test_id": "viz_001",
      "prompt_type": "domain_jargon",
      "prompt": "Generate a frequency distribution with 20 bins and kernel density overlay",
      "expected_tools": ["viz_histogram"],
      "acceptable_tools": ["viz_histogram", "viz_density"],
      "dataset_context": "census: income, age, education, occupation",
      "linguistic_features": ["domain_jargon", "specific_parameters"]
    },
    {
      "id": "nat_viz_003",
      "base_test_id": "viz_002",
      "prompt_type": "verbose",
      "prompt": "I want to see the distribution of income in my dataset. I'm particularly interested in whether it follows a normal distribution or if it's skewed. A graphical representation would be helpful.",
      "expected_tools": ["viz_histogram"],
      "acceptable_tools": ["viz_histogram", "viz_density", "viz_boxplot"],
      "dataset_context": "census: income, age, education, occupation",
      "linguistic_features": ["verbose", "goal_description"]
    },
    {
      "id": "nat_viz_004",
      "base_test_id": "viz_003",
      "prompt_type": "typos",
      "prompt": "scater plot of edcuation vs incmoe",
      "expected_tools": ["viz_scatter"],
      "acceptable_tools": ["viz_scatter"],
      "dataset_context": "census: income, age, education, occupation",
      "linguistic_features": ["typos", "misspellings"]
    },
    {
      "id": "nat_viz_005",
      "base_test_id": "viz_004",
      "prompt_type": "informal",
      "prompt": "plot x against y with a trend line",
      "expected_tools": ["viz_scatter"],
      "acceptable_tools": ["viz_scatter", "viz_regression_plot"],
      "dataset_context": "generic: x, y",
      "linguistic_features": ["informal_register", "generic_reference"]
    },
    {
      "id": "nat_viz_006",
      "base_test_id": "viz_005",
      "prompt_type": "ambiguous",
      "prompt": "visualize the relationship",
      "expected_tools": ["viz_scatter"],
      "acceptable_tools": ["viz_scatter", "viz_heatmap", "compute_correlation"],
      "dataset_context": "data: var1, var2",
      "linguistic_features": ["ambiguous", "minimal_context"]
    },
    {
      "id": "nat_viz_007",
      "base_test_id": "viz_006",
      "prompt_type": "verbose",
      "prompt": "I have multiple variables and I want to understand which ones are correlated with each other. Can you create some kind of visualization that shows all the pairwise correlations at once? Maybe something like a matrix or heatmap?",
      "expected_tools": ["viz_heatmap"],
      "acceptable_tools": ["viz_heatmap", "viz_correlation_matrix"],
      "dataset_context": "survey: var1, var2, var3, var4, var5",
      "linguistic_features": ["verbose", "seeking_guidance"]
    },
    {
      "id": "nat_viz_008",
      "base_test_id": "viz_007",
      "prompt_type": "informal",
      "prompt": "boxplots by category",
      "expected_tools": ["viz_boxplot"],
      "acceptable_tools": ["viz_boxplot"],
      "dataset_context": "experiment: value, group",
      "linguistic_features": ["informal_register", "shorthand"]
    },
    {
      "id": "nat_viz_009",
      "base_test_id": "viz_008",
      "prompt_type": "domain_jargon",
      "prompt": "Create a coefficient plot with 95% confidence intervals for the regression output",
      "expected_tools": ["viz_coef_plot"],
      "acceptable_tools": ["viz_coef_plot"],
      "dataset_context": "regression_output: coefficients, std_errors, names",
      "linguistic_features": ["domain_jargon", "specific_visualization"]
    },
    {
      "id": "nat_viz_010",
      "base_test_id": "viz_009",
      "prompt_type": "typos",
      "prompt": "correaltion hetamap for all variabels",
      "expected_tools": ["viz_heatmap"],
      "acceptable_tools": ["viz_heatmap", "viz_correlation_matrix"],
      "dataset_context": "data: v1, v2, v3, v4, v5, v6",
      "linguistic_features": ["typos", "misspellings"]
    },
    {
      "id": "nat_viz_011",
      "base_test_id": "viz_010",
      "prompt_type": "verbose",
      "prompt": "After running my regression, I want to check the model diagnostics visually. Can you create plots showing the residuals versus fitted values, a Q-Q plot for normality, and maybe some other diagnostic plots?",
      "expected_tools": ["viz_residual_diagnostics"],
      "acceptable_tools": ["viz_residual_diagnostics", "viz_qq_plot", "viz_scatter"],
      "dataset_context": "regression_output: residuals, fitted, y, x1, x2",
      "linguistic_features": ["verbose", "multiple_requests"]
    },
    {
      "id": "nat_viz_012",
      "base_test_id": "viz_001",
      "prompt_type": "ambiguous",
      "prompt": "show me the data",
      "expected_tools": ["viz_histogram"],
      "acceptable_tools": ["viz_histogram", "viz_scatter", "viz_boxplot", "viz_summary"],
      "dataset_context": "data: value",
      "linguistic_features": ["ambiguous", "extremely_vague"]
    }
  ]
}
