{
  "category": "parameter_extraction",
  "description": "Tests for evaluating LLM ability to extract and correctly specify tool parameters",
  "tests": [
    {
      "id": "param_reg_001",
      "prompt": "Regress investment on firm value and capital with HC2 robust standard errors",
      "expected_tool": "regression_ols",
      "dataset_context": "grunfeld dataset: firm, year, inv, value, capital",
      "expected_parameters": {
        "y_col": {"expected": "inv", "alternatives": ["investment"]},
        "x_cols": {"expected": ["value", "capital"], "order_matters": false},
        "robust": {"expected": "hc2", "alternatives": ["HC2"]},
        "intercept": {"expected": true, "implicit": true}
      },
      "parameter_difficulty": {
        "y_col": "explicit",
        "x_cols": "explicit",
        "robust": "explicit",
        "intercept": "implicit_default"
      }
    },
    {
      "id": "param_reg_002",
      "prompt": "Run OLS without an intercept regressing wages on education and experience",
      "expected_tool": "regression_ols",
      "dataset_context": "wages dataset: wage, education, experience, tenure",
      "expected_parameters": {
        "y_col": {"expected": "wage", "alternatives": ["wages"]},
        "x_cols": {"expected": ["education", "experience"], "order_matters": false},
        "intercept": {"expected": false, "alternatives": [false]},
        "robust": {"expected": "none", "implicit": true}
      },
      "parameter_difficulty": {
        "y_col": "explicit",
        "x_cols": "explicit",
        "intercept": "explicit_negation",
        "robust": "implicit_default"
      }
    },
    {
      "id": "param_reg_003",
