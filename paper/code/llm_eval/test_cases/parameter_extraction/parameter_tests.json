    {
      "id": "param_reg_001",
      "prompt": "Regress investment on firm value and capital",
      "expected_tool": "regression_ols",
      "dataset_context": "grunfeld dataset: firm, year, inv, value, capital",
      "expected_parameters": {
        "y": {"expected": "inv", "alternatives": ["investment"]},
        "x": {"expected": ["value", "capital"], "order_matters": false}
      },
      "parameter_difficulty": {
        "y": "explicit",
        "x": "explicit"
      }
    },
    {
