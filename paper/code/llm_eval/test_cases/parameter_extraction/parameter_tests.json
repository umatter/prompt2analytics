{
  "category": "parameter_extraction",
  "description": "Tests for evaluating LLM ability to extract and correctly specify tool parameters. Parameter names match actual MCP tool schemas.",
  "version": "2.0",
  "changelog": "v2.0: Fixed parameter names to match actual MCP tool request structs. Removed tests for non-existent tools. Fixed tool names.",
