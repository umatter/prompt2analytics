{
  "category": "interpretation_regression",
  "description": "Tests for evaluating LLM ability to correctly interpret regression output",
  "tests": [
    {
      "id": "int_reg_001",
      "task_type": "coefficient_interpretation",
      "simulated_output": {
        "model": "OLS",
        "dependent_var": "log_wage",
        "coefficients": {"intercept": 1.5, "education": 0.0832, "experience": 0.0412, "experience_sq": -0.0007},
        "std_errors": {"intercept": 0.05, "education": 0.0045, "experience": 0.0032, "experience_sq": 0.0001},
        "p_values": {"intercept": 0.0001, "education": 0.0001, "experience": 0.0001, "experience_sq": 0.0001},
        "r_squared": 0.312,
        "n_obs": 1000
      },
      "interpretation_prompt": "What does the education coefficient tell us about the relationship between education and wages?",
      "expected_elements": [
        {"element": "percentage_interpretation", "required": true, "description": "Interprets as ~8.3% increase in wages per year of education"},
        {"element": "log_scale_awareness", "required": true, "description": "Recognizes log transformation implies percentage effects"},
        {"element": "statistical_significance", "required": true, "description": "Notes the coefficient is highly significant"},
        {"element": "ceteris_paribus", "required": false, "description": "Mentions holding other variables constant"}
      ],
      "incorrect_interpretations": [
        {"error": "absolute_interpretation", "description": "Interprets as $0.08 increase in wages"},
        {"error": "unit_confusion", "description": "Interprets as 8.32% instead of ~8.3%"},
        {"error": "exact_percentage", "description": "Uses coefficient directly as percentage without exp() consideration"}
      ]
    },
    {
      "id": "int_reg_002",
      "task_type": "quadratic_interpretation",
      "simulated_output": {
        "model": "OLS",
        "dependent_var": "wage",
        "coefficients": {"intercept": 5.2, "experience": 1.25, "experience_sq": -0.018},
        "std_errors": {"intercept": 0.3, "experience": 0.08, "experience_sq": 0.002},
        "p_values": {"intercept": 0.0001, "experience": 0.0001, "experience_sq": 0.0001}
      },
      "interpretation_prompt": "What is the marginal effect of an additional year of experience? Is there a turning point?",
      "expected_elements": [
        {"element": "marginal_effect_formula", "required": true, "description": "Computes dY/dX = 1.25 - 0.036*experience"},
        {"element": "turning_point", "required": true, "description": "Calculates turning point at ~34.7 years"},
        {"element": "diminishing_returns", "required": true, "description": "Notes diminishing returns to experience"},
        {"element": "negative_squared_term", "required": false, "description": "Interprets negative squared term correctly"}
      ],
      "incorrect_interpretations": [
        {"error": "linear_interpretation", "description": "Ignores squared term and reports only linear coefficient"},
        {"error": "wrong_turning_point", "description": "Calculates turning point incorrectly"}
      ]
    },
    {
      "id": "int_reg_003",
      "task_type": "dummy_variable_interpretation",
      "simulated_output": {
        "model": "OLS",
        "dependent_var": "wage",
        "coefficients": {"intercept": 12.5, "education": 1.2, "female": -2.8, "married": 1.5},
        "std_errors": {"intercept": 0.5, "education": 0.1, "female": 0.4, "married": 0.35},
        "p_values": {"intercept": 0.0001, "education": 0.0001, "female": 0.0001, "married": 0.0001}
      },
      "interpretation_prompt": "How do you interpret the coefficient on the female dummy variable?",
      "expected_elements": [
        {"element": "gender_gap", "required": true, "description": "Women earn $2.80 less than men on average"},
        {"element": "reference_category", "required": true, "description": "Compares to reference category (male)"},
        {"element": "controlled_comparison", "required": true, "description": "Notes this is controlling for education and marital status"},
        {"element": "statistical_significance", "required": false, "description": "Notes the gap is statistically significant"}
      ],
      "incorrect_interpretations": [
        {"error": "causal_language", "description": "Claims being female 'causes' lower wages without caution"},
        {"error": "percentage_interpretation", "description": "Incorrectly interprets as percentage"}
      ]
    },
    {
      "id": "int_reg_004",
      "task_type": "interaction_interpretation",
      "simulated_output": {
        "model": "OLS",
        "dependent_var": "wage",
        "coefficients": {"intercept": 10.0, "education": 1.5, "female": -3.0, "education_female": 0.4},
        "std_errors": {"intercept": 0.5, "education": 0.15, "female": 1.2, "education_female": 0.12},
        "p_values": {"intercept": 0.0001, "education": 0.0001, "female": 0.012, "education_female": 0.001}
      },
      "interpretation_prompt": "How do you interpret the interaction between education and female?",
      "expected_elements": [
        {"element": "differential_effect", "required": true, "description": "Education effect differs by gender"},
        {"element": "male_effect", "required": true, "description": "For men: each year of education increases wage by $1.50"},
        {"element": "female_effect", "required": true, "description": "For women: each year increases wage by $1.90 (1.5+0.4)"},
        {"element": "gap_closure", "required": false, "description": "Higher education partially closes the gender gap"}
      ],
      "incorrect_interpretations": [
        {"error": "additive_interpretation", "description": "Simply adds interaction to base effect without considering conditioning"},
        {"error": "main_effect_only", "description": "Ignores interaction and interprets main effects separately"}
      ]
    },
    {
      "id": "int_reg_005",
      "task_type": "r_squared_interpretation",
      "simulated_output": {
        "model": "OLS",
        "dependent_var": "firm_value",
        "coefficients": {"intercept": 100, "r_and_d": 2.5, "patents": 0.8},
        "r_squared": 0.08,
        "adj_r_squared": 0.076,
        "n_obs": 5000,
        "f_stat": 217.4,
        "f_pvalue": 0.0001
      },
      "interpretation_prompt": "The R-squared is only 0.08. Does this mean the model is useless?",
      "expected_elements": [
        {"element": "context_matters", "required": true, "description": "Low R² is common in cross-sectional firm/individual data"},
        {"element": "coefficients_valid", "required": true, "description": "Coefficients can still be meaningful and unbiased"},
        {"element": "f_test_significant", "required": true, "description": "Joint F-test is highly significant"},
        {"element": "prediction_vs_explanation", "required": false, "description": "Distinguishes predictive vs explanatory goals"}
      ],
      "incorrect_interpretations": [
        {"error": "dismissive", "description": "Claims model is worthless due to low R²"},
        {"error": "overemphasis", "description": "Focuses only on R² ignoring significant coefficients"}
      ]
    },
    {
      "id": "int_reg_006",
      "task_type": "robust_se_interpretation",
      "simulated_output": {
        "model": "OLS with HC1",
        "dependent_var": "investment",
        "coefficients": {"value": 0.115},
        "std_errors_ols": {"value": 0.008},
        "std_errors_hc1": {"value": 0.015},
        "p_values_ols": {"value": 0.0001},
        "p_values_hc1": {"value": 0.0001}
      },
      "interpretation_prompt": "The robust standard errors are almost twice as large as the OLS standard errors. What does this imply?",
      "expected_elements": [
        {"element": "heteroskedasticity_presence", "required": true, "description": "Suggests heteroskedasticity in the data"},
        {"element": "ols_se_biased", "required": true, "description": "OLS SEs are biased downward"},
        {"element": "inference_affected", "required": true, "description": "Inference using OLS SEs would be too optimistic"},
        {"element": "coefficient_unchanged", "required": false, "description": "Point estimate is unchanged"}
      ],
      "incorrect_interpretations": [
        {"error": "coefficient_bias", "description": "Claims the coefficient estimate is biased"},
        {"error": "model_invalid", "description": "Claims the entire model is invalid"}
      ]
    },
    {
      "id": "int_reg_007",
      "task_type": "multicollinearity_interpretation",
      "simulated_output": {
        "model": "OLS",
        "dependent_var": "house_price",
        "coefficients": {"sqft": 150, "rooms": -5000, "bathrooms": 8000},
        "std_errors": {"sqft": 20, "rooms": 4000, "bathrooms": 6000},
        "vif": {"sqft": 8.2, "rooms": 12.5, "bathrooms": 9.8},
        "correlation_sqft_rooms": 0.85
      },
      "interpretation_prompt": "The VIFs are high and rooms has a negative coefficient. Is this a problem?",
      "expected_elements": [
        {"element": "multicollinearity_identified", "required": true, "description": "Identifies multicollinearity from high VIFs"},
        {"element": "sign_flip_explanation", "required": true, "description": "Explains negative sign is due to multicollinearity"},
        {"element": "inflated_se", "required": true, "description": "Notes standard errors are inflated"},
        {"element": "joint_significance", "required": false, "description": "Suggests checking joint significance"}
      ],
      "incorrect_interpretations": [
        {"error": "literal_interpretation", "description": "Interprets negative coefficient as 'more rooms = lower price'"},
        {"error": "data_error", "description": "Assumes there must be an error in the data"}
      ]
    },
    {
      "id": "int_reg_008",
      "task_type": "clustered_se_interpretation",
      "simulated_output": {
        "model": "OLS with clustered SE",
        "dependent_var": "student_score",
        "coefficients": {"class_size": -0.5},
        "std_errors_ols": {"class_size": 0.05},
        "std_errors_clustered": {"class_size": 0.22},
        "cluster_var": "school",
        "n_clusters": 50
      },
      "interpretation_prompt": "Why did clustering by school increase the standard errors so dramatically?",
      "expected_elements": [
        {"element": "within_cluster_correlation", "required": true, "description": "Students within schools are correlated"},
        {"element": "effective_sample_size", "required": true, "description": "Effective sample size closer to number of schools"},
        {"element": "design_effect", "required": false, "description": "Mentions design effect or intraclass correlation"},
        {"element": "inference_implications", "required": true, "description": "Standard inference would be overconfident"}
      ],
      "incorrect_interpretations": [
        {"error": "data_quality", "description": "Assumes larger SE means worse data quality"},
        {"error": "model_misspecification", "description": "Claims model is misspecified"}
      ]
    }
  ]
}
