{
  "category": "interpretation_hypothesis",
  "description": "Tests for evaluating LLM ability to correctly interpret hypothesis test results",
  "tests": [
    {
      "id": "int_hyp_001",
      "task_type": "p_value_interpretation",
      "simulated_output": {
        "test": "Two-sample t-test",
        "null_hypothesis": "mean_A = mean_B",
        "t_statistic": 2.45,
        "p_value": 0.016,
        "mean_A": 52.3,
        "mean_B": 48.7,
        "n_A": 50,
        "n_B": 55,
        "alpha": 0.05
      },
      "interpretation_prompt": "The p-value is 0.016. What does this mean and what should we conclude?",
      "expected_elements": [
        {"element": "reject_null", "required": true, "description": "Rejects null at α=0.05"},
        {"element": "probability_interpretation", "required": true, "description": "Probability of observing this result if null were true"},
        {"element": "evidence_language", "required": true, "description": "Uses 'evidence against' rather than 'proves'"},
        {"element": "practical_significance", "required": false, "description": "Distinguishes statistical from practical significance"}
      ],
      "incorrect_interpretations": [
        {"error": "probability_of_null", "description": "Claims p=0.016 means 1.6% chance null is true"},
        {"error": "proves_alternative", "description": "Claims result 'proves' the alternative hypothesis"},
        {"error": "effect_size_confusion", "description": "Interprets p-value as effect size"}
      ]
    },
    {
      "id": "int_hyp_002",
      "task_type": "confidence_interval_interpretation",
      "simulated_output": {
        "test": "Two-sample t-test",
        "mean_difference": 3.6,
        "ci_95": [0.8, 6.4],
        "p_value": 0.012
      },
      "interpretation_prompt": "The 95% confidence interval for the difference is [0.8, 6.4]. What does this tell us?",
      "expected_elements": [
        {"element": "range_of_plausible_values", "required": true, "description": "Range of plausible values for true difference"},
        {"element": "excludes_zero", "required": true, "description": "Zero not in interval, consistent with significant p-value"},
        {"element": "repeated_sampling", "required": false, "description": "Correct frequentist interpretation about repeated sampling"},
        {"element": "uncertainty_quantification", "required": true, "description": "Provides measure of estimation uncertainty"}
      ],
      "incorrect_interpretations": [
        {"error": "probability_statement", "description": "Claims 95% probability true value is in interval"},
        {"error": "all_values_likely", "description": "Claims all values in interval are equally likely"}
      ]
    },
    {
      "id": "int_hyp_003",
      "task_type": "non_significant_interpretation",
      "simulated_output": {
        "test": "Two-sample t-test",
        "null_hypothesis": "mean_treatment = mean_control",
        "t_statistic": 1.2,
        "p_value": 0.23,
        "mean_difference": 2.1,
        "ci_95": [-1.5, 5.7],
        "n_treatment": 25,
        "n_control": 28
      },
      "interpretation_prompt": "The p-value is 0.23 so we fail to reject the null. Does this mean the treatment has no effect?",
      "expected_elements": [
        {"element": "cannot_prove_null", "required": true, "description": "Failing to reject ≠ accepting null"},
        {"element": "power_considerations", "required": true, "description": "Small sample may lack power to detect effect"},
        {"element": "ci_includes_meaningful", "required": true, "description": "CI includes potentially meaningful effects"},
        {"element": "absence_of_evidence", "required": false, "description": "'Absence of evidence is not evidence of absence'"}
      ],
      "incorrect_interpretations": [
        {"error": "proves_no_effect", "description": "Claims the treatment definitely has no effect"},
        {"error": "accept_null", "description": "States we 'accept' the null hypothesis"}
      ]
    },
    {
      "id": "int_hyp_004",
      "task_type": "anova_interpretation",
      "simulated_output": {
        "test": "One-way ANOVA",
        "f_statistic": 8.45,
        "p_value": 0.0003,
        "group_means": {"A": 45.2, "B": 52.8, "C": 48.1},
        "n_groups": 3,
        "n_total": 120,
        "eta_squared": 0.13
      },
      "interpretation_prompt": "The ANOVA is significant with p=0.0003. What can we conclude about the group differences?",
      "expected_elements": [
        {"element": "at_least_one_differs", "required": true, "description": "At least one group mean differs from others"},
        {"element": "not_all_pairs", "required": true, "description": "Doesn't tell us which specific pairs differ"},
        {"element": "post_hoc_needed", "required": true, "description": "Need post-hoc tests for pairwise comparisons"},
        {"element": "effect_size", "required": false, "description": "η²=0.13 suggests moderate effect size"}
      ],
      "incorrect_interpretations": [
        {"error": "all_different", "description": "Claims all groups differ from each other"},
        {"error": "specific_pair", "description": "Claims specific pairs differ without post-hoc"}
      ]
    },
    {
      "id": "int_hyp_005",
      "task_type": "chi_squared_interpretation",
      "simulated_output": {
        "test": "Chi-squared test of independence",
        "chi_squared": 15.8,
        "p_value": 0.0004,
        "df": 2,
        "contingency_table": {
          "outcome_yes": {"treatment": 45, "control": 28},
          "outcome_no": {"treatment": 35, "control": 52}
        },
        "cramers_v": 0.31
      },
      "interpretation_prompt": "The chi-squared test is significant. What does this tell us about the relationship between treatment and outcome?",
      "expected_elements": [
        {"element": "association_exists", "required": true, "description": "Treatment and outcome are associated"},
        {"element": "not_causal", "required": true, "description": "Association ≠ causation"},
        {"element": "direction_of_association", "required": true, "description": "Treatment group has higher success rate"},
        {"element": "effect_size", "required": false, "description": "Cramér's V indicates moderate association"}
      ],
      "incorrect_interpretations": [
        {"error": "causal_claim", "description": "Claims treatment causes better outcomes"},
        {"error": "magnitude_from_chi", "description": "Tries to interpret χ² value as effect size"}
      ]
    },
    {
      "id": "int_hyp_006",
      "task_type": "normality_test_interpretation",
      "simulated_output": {
        "test": "Shapiro-Wilk test",
        "w_statistic": 0.92,
        "p_value": 0.001,
        "n": 100,
        "skewness": 0.85,
        "kurtosis": 4.2
      },
      "interpretation_prompt": "The Shapiro-Wilk test rejects normality with p=0.001. What should we do about our regression analysis?",
      "expected_elements": [
        {"element": "robustness_consideration", "required": true, "description": "OLS is robust to non-normality with large n"},
        {"element": "clt_invocation", "required": true, "description": "Central Limit Theorem helps with n=100"},
        {"element": "alternatives_mentioned", "required": false, "description": "Mentions robust SEs or bootstrap"},
        {"element": "graphical_check", "required": false, "description": "Suggests visual inspection (Q-Q plot)"}
      ],
      "incorrect_interpretations": [
        {"error": "regression_invalid", "description": "Claims OLS results are completely invalid"},
        {"error": "transform_required", "description": "Insists on transformation without considering sample size"}
      ]
    },
    {
      "id": "int_hyp_007",
      "task_type": "heteroskedasticity_test_interpretation",
      "simulated_output": {
        "test": "Breusch-Pagan test",
        "lm_statistic": 18.5,
        "p_value": 0.002,
        "df": 3,
        "regression_context": "wage regression with education, experience, tenure"
      },
      "interpretation_prompt": "The Breusch-Pagan test rejects homoskedasticity. How does this affect our OLS results?",
      "expected_elements": [
        {"element": "coefficients_unbiased", "required": true, "description": "OLS coefficients remain unbiased"},
        {"element": "se_affected", "required": true, "description": "Standard errors are inconsistent"},
        {"element": "robust_se_solution", "required": true, "description": "Use robust (HC) standard errors"},
        {"element": "efficiency_loss", "required": false, "description": "OLS is no longer BLUE"}
      ],
      "incorrect_interpretations": [
        {"error": "coefficients_biased", "description": "Claims coefficients are biased"},
        {"error": "model_useless", "description": "Claims entire regression is invalid"}
      ]
    },
    {
      "id": "int_hyp_008",
      "task_type": "autocorrelation_test_interpretation",
      "simulated_output": {
        "test": "Durbin-Watson test",
        "dw_statistic": 0.85,
        "interpretation": "Positive autocorrelation",
        "critical_values": {"dl": 1.65, "du": 1.69},
        "n": 100,
        "k": 3
      },
      "interpretation_prompt": "The Durbin-Watson statistic is 0.85. What are the implications for our regression analysis?",
      "expected_elements": [
        {"element": "positive_autocorrelation", "required": true, "description": "Strong positive autocorrelation detected"},
        {"element": "se_affected", "required": true, "description": "Standard errors are underestimated"},
        {"element": "solutions", "required": true, "description": "Mentions HAC SEs, GLS, or model respecification"},
        {"element": "possible_causes", "required": false, "description": "Could indicate omitted variable or wrong functional form"}
      ],
      "incorrect_interpretations": [
        {"error": "coefficients_biased", "description": "Claims coefficients are biased (not necessarily true)"},
        {"error": "ignore_problem", "description": "Claims DW close to 0 is acceptable"}
      ]
    },
    {
      "id": "int_hyp_009",
      "task_type": "power_interpretation",
      "simulated_output": {
        "test": "Power analysis",
        "effect_size": 0.3,
        "n_per_group": 30,
        "alpha": 0.05,
        "power": 0.42
      },
      "interpretation_prompt": "Our study has 42% power to detect the expected effect. Is this adequate?",
      "expected_elements": [
        {"element": "underpowered", "required": true, "description": "Study is underpowered (convention is 80%)"},
        {"element": "type_ii_risk", "required": true, "description": "High risk of Type II error (false negative)"},
        {"element": "sample_size_recommendation", "required": true, "description": "Suggests increasing sample size"},
        {"element": "planning_implications", "required": false, "description": "Should address before data collection"}
      ],
      "incorrect_interpretations": [
        {"error": "adequate", "description": "Claims 42% power is adequate"},
        {"error": "significance_confusion", "description": "Confuses power with significance level"}
      ]
    },
    {
      "id": "int_hyp_010",
      "task_type": "multiple_testing_interpretation",
      "simulated_output": {
        "tests_performed": 20,
        "significant_at_05": 3,
        "p_values": [0.001, 0.023, 0.041, 0.08, 0.12, 0.15, 0.18, 0.22, 0.28, 0.35, 0.42, 0.48, 0.55, 0.62, 0.68, 0.75, 0.82, 0.88, 0.92, 0.97],
        "bonferroni_threshold": 0.0025
      },
      "interpretation_prompt": "We found 3 significant results out of 20 tests at α=0.05. How should we interpret this?",
      "expected_elements": [
        {"element": "multiple_testing_problem", "required": true, "description": "Expected ~1 false positive by chance"},
        {"element": "adjustment_needed", "required": true, "description": "Should adjust for multiple comparisons"},
        {"element": "methods_mentioned", "required": true, "description": "Mentions Bonferroni, FDR, or similar"},
        {"element": "replication", "required": false, "description": "Suggests replication to confirm findings"}
      ],
      "incorrect_interpretations": [
        {"error": "all_real", "description": "Claims all 3 are definitely real effects"},
        {"error": "ignore_problem", "description": "Ignores multiple testing entirely"}
      ]
    }
  ]
}
