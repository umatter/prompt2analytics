          "expected_tool": "ts_granger_test",
          "acceptable_tools": ["ts_granger_test", "ts_causality"],
          "context_from_previous": true
        },
        {
          "turn": 3,
          "user_prompt": "Estimate a bivariate VAR to quantify the relationships",
