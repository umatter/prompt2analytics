{
  "category": "multi_turn_timeseries",
  "description": "Multi-turn conversations testing time series analysis workflows",
  "conversations": [
    {
      "id": "mt_ts_001",
      "description": "ARIMA model selection and forecasting",
      "dataset_context": "gdp_quarterly: gdp, date (quarterly from 1960-2023)",
      "turns": [
        {
          "turn": 1,
          "user_prompt": "I want to forecast GDP. First, test if the series is stationary",
          "expected_tool": "timeseries_pp_test",
          "acceptable_tools": ["timeseries_pp_test"],
          "context_from_previous": false
        },
        {
          "turn": 2,
          "user_prompt": "The series is non-stationary. Take the first difference and test again",
          "expected_tool": "timeseries_pp_test",
          "acceptable_tools": ["timeseries_pp_test"],
          "context_from_previous": true
        },
        {
          "turn": 3,
          "user_prompt": "Now fit an ARIMA model with automatic order selection",
          "expected_tool": "ts_arima_fit",
          "acceptable_tools": ["ts_arima_fit"],
          "context_from_previous": true
        },
        {
          "turn": 4,
          "user_prompt": "Generate forecasts for the next 8 quarters with confidence intervals",
          "expected_tool": "ts_arima_forecast",
          "acceptable_tools": ["ts_arima_forecast", "ts_arima_fit"],
          "context_from_previous": true
        },
        {
          "turn": 5,
          "user_prompt": "Plot the forecasts along with the historical data",
          "expected_tool": "viz_line",
          "acceptable_tools": ["viz_line", "viz_ts"],
          "context_from_previous": true
        }
      ]
    },
    {
