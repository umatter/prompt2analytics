{
  "category": "multi_turn_timeseries",
  "description": "Multi-turn conversations testing time series analysis workflows",
  "conversations": [
    {
      "id": "mt_ts_001",
      "description": "ARIMA model selection and forecasting",
      "dataset_context": "gdp_quarterly: gdp, date (quarterly from 1960-2023)",
      "turns": [
        {
          "turn": 1,
          "user_prompt": "I want to forecast GDP. First, test if the series is stationary",
          "expected_tool": "ts_adf_test",
          "acceptable_tools": ["ts_adf_test", "ts_kpss_test", "ts_unit_root"],
          "context_from_previous": false
        },
        {
          "turn": 2,
          "user_prompt": "The series is non-stationary. Take the first difference and test again",
          "expected_tool": "ts_adf_test",
          "acceptable_tools": ["ts_adf_test", "ts_diff"],
          "context_from_previous": true
        },
        {
          "turn": 3,
          "user_prompt": "Now fit an ARIMA model with automatic order selection",
          "expected_tool": "ts_arima",
          "acceptable_tools": ["ts_arima", "ts_auto_arima"],
          "context_from_previous": true
        },
        {
          "turn": 4,
          "user_prompt": "Generate forecasts for the next 8 quarters with confidence intervals",
          "expected_tool": "ts_forecast",
          "acceptable_tools": ["ts_forecast", "ts_arima"],
          "context_from_previous": true
        },
        {
          "turn": 5,
          "user_prompt": "Plot the forecasts along with the historical data",
          "expected_tool": "viz_forecast",
          "acceptable_tools": ["viz_forecast", "viz_ts", "viz_line"],
          "context_from_previous": true
        }
      ]
    },
    {
      "id": "mt_ts_002",
      "description": "VAR model for macroeconomic analysis",
      "dataset_context": "macro_quarterly: gdp, inflation, interest_rate, unemployment, date",
      "turns": [
        {
          "turn": 1,
          "user_prompt": "I want to study the dynamic relationships between GDP, inflation, and interest rates",
          "expected_tool": "ts_var",
          "acceptable_tools": ["ts_var", "ts_vecm"],
          "context_from_previous": false
        },
        {
          "turn": 2,
          "user_prompt": "Select the optimal lag order using information criteria",
          "expected_tool": "ts_var_select",
          "acceptable_tools": ["ts_var_select", "ts_var"],
          "context_from_previous": true
        },
        {
          "turn": 3,
          "user_prompt": "Estimate the VAR with the selected lag order",
          "expected_tool": "ts_var",
          "acceptable_tools": ["ts_var"],
          "context_from_previous": true
        },
        {
          "turn": 4,
          "user_prompt": "Compute impulse response functions for a monetary policy shock",
          "expected_tool": "ts_irf",
          "acceptable_tools": ["ts_irf", "ts_var_irf"],
          "context_from_previous": true
        },
        {
          "turn": 5,
          "user_prompt": "Plot the IRFs with confidence bands",
          "expected_tool": "viz_irf",
          "acceptable_tools": ["viz_irf", "viz_line"],
          "context_from_previous": true
        }
      ]
    },
    {
      "id": "mt_ts_003",
      "description": "Cointegration analysis",
      "dataset_context": "exchange_rates: usd_eur, usd_gbp, date (daily)",
      "turns": [
        {
          "turn": 1,
          "user_prompt": "Test whether USD/EUR and USD/GBP exchange rates are cointegrated",
          "expected_tool": "ts_coint_test",
          "acceptable_tools": ["ts_coint_test", "ts_johansen"],
          "context_from_previous": false
        },
        {
          "turn": 2,
          "user_prompt": "Use the Johansen procedure to determine the number of cointegrating relationships",
          "expected_tool": "ts_johansen",
          "acceptable_tools": ["ts_johansen", "ts_coint_test"],
          "context_from_previous": true
        },
        {
          "turn": 3,
          "user_prompt": "Estimate a Vector Error Correction Model",
          "expected_tool": "ts_vecm",
          "acceptable_tools": ["ts_vecm"],
          "context_from_previous": true
        }
      ]
    },
    {
