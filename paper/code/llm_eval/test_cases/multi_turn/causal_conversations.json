          "expected_tool": "diff_in_diff",
          "acceptable_tools": ["diff_in_diff", "panel_fe"],
          "context_from_previous": false
        },
        {
          "turn": 2,
          "user_prompt": "Estimate the DiD with state and year fixed effects",
          "expected_tool": "diff_in_diff",
          "acceptable_tools": ["diff_in_diff", "panel_twoway"],
          "context_from_previous": true
        },
        {
          "turn": 3,
          "user_prompt": "Test for parallel pre-trends using an event study specification",
          "expected_tool": "diff_event_study",
          "acceptable_tools": ["diff_event_study", "diff_in_diff"],
          "context_from_previous": true
        },
        {
          "turn": 4,
          "user_prompt": "Plot the event study coefficients with confidence intervals",
          "expected_tool": "viz_event_study",
          "acceptable_tools": ["viz_event_study", "viz_coef_plot", "viz_line"],
          "context_from_previous": true
        }
      ]
    },
    {
