# ============================================================================
# Comparison Function
# ============================================================================

compare_results <- function(r_value, rust_value, tolerance, name) {
  diff <- abs(r_value - rust_value)
  pass <- diff < tolerance

  status <- if (pass) "PASS" else "FAIL"
  cat(sprintf("  %s: R=%.10f, Rust=%.10f, Diff=%.2e, Tol=%.2e [%s]\n",
              name, r_value, rust_value, diff, tolerance, status))

  return(pass)
}

# ============================================================================
# Validate Against Rust Results
# ============================================================================

# To validate, the Rust test should output its results to a JSON file
# that this script can read and compare.
#
# Example validation workflow:
#
# 1. Run Rust test: cargo test -p p2a-core -- test_validate_{{METHOD_ID}} --nocapture
# 2. Rust test writes results to: validation_output/{{METHOD_ID}}_rust.json
# 3. This script reads both R and Rust results and compares

cat("\n=== Validation Comparison ===\n")

rust_file <- "validation_output/{{METHOD_ID}}_rust.json"
if (file.exists(rust_file)) {
  rust_results <- fromJSON(rust_file)

  cat("\nComparing results:\n")
  all_pass <- TRUE

  {{COMPARISON_CODE}}

  if (all_pass) {
    cat("\n[SUCCESS] All validations passed!\n")
  } else {
    cat("\n[FAILURE] Some validations failed. Check results above.\n")
  }
} else {
  cat(sprintf("\nNote: Rust results file not found: %s\n", rust_file))
  cat("Run the Rust validation test first:\n")
  cat("  cargo test -p p2a-core -- test_validate_{{METHOD_ID}} --nocapture\n")
}

# ============================================================================
# Output Summary for Validation Doc
# ============================================================================

cat("\n=== Copy to Validation Doc ===\n")
cat("```markdown\n")
