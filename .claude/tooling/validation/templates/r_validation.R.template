TOLERANCE_COEF <- {{TOLERANCE_COEF}}    # Coefficient tolerance
TOLERANCE_SE <- {{TOLERANCE_SE}}        # Standard error tolerance
TOLERANCE_PVAL <- {{TOLERANCE_PVAL}}    # P-value tolerance

# ============================================================================
# Test Case 1: Synthetic Data with Known DGP
# ============================================================================

cat("=== Test Case 1: Synthetic Data ===\n")

# Generate synthetic data with known true parameters
{{SYNTHETIC_DATA_CODE}}

# Fit R model
{{R_FIT_CODE}}

# Extract R results
r_results <- list(
  {{R_RESULTS_EXTRACTION}}
)

# Print R results for comparison with Rust
cat("\nR Results (copy to validation doc):\n")
cat("------------------------------------------\n")
{{R_RESULTS_PRINT}}

# Save reference values as JSON
output <- list(
  test_case = "synthetic",
  method = "{{METHOD_ID}}",
  r_function = "{{R_FUNCTION}}",
  seed = 42,
  {{JSON_OUTPUT_FIELDS}}
  r_version = paste(R.version$major, R.version$minor, sep = "."),
  timestamp = format(Sys.time(), "%Y-%m-%d %H:%M:%S")
)

dir.create("validation_output", showWarnings = FALSE)
write(toJSON(output, auto_unbox = TRUE, pretty = TRUE, digits = 15),
