#!/usr/bin/env Rscript
# R Benchmark Template for {{METHOD_NAME}}
# Generated by /validate-method command
#
# This script benchmarks R's {{R_FUNCTION}} against p2a-core's Rust implementation
# Run with: Rscript benchmark_{{METHOD_ID}}.R

# ============================================================================
# Setup
# ============================================================================

# Install packages if needed
required_packages <- c("microbenchmark", "jsonlite"{{EXTRA_PACKAGES}})
for (pkg in required_packages) {
  if (!require(pkg, character.only = TRUE, quietly = TRUE)) {
    install.packages(pkg, repos = "https://cloud.r-project.org")
    library(pkg, character.only = TRUE)
  }
}

# Ensure reproducibility (match Rust seed)
set.seed(42)

# ============================================================================
# Data Generation
# ============================================================================

# Generate data matching the Rust benchmark DGP
# CUSTOMIZE: Modify this function for method-specific data generation
generate_data <- function(n, k = 5) {
  {{DATA_GENERATION_CODE}}
}

# ============================================================================
# Benchmark Function
# ============================================================================

benchmark_{{METHOD_ID}} <- function() {
  results <- list()

  # Benchmark at multiple sample sizes
  for (n in c(100, 1000, 10000{{EXTRA_SIZES}})) {
    cat(sprintf("Benchmarking {{METHOD_NAME}} with n=%d\n", n))

    # Generate data
    data <- generate_data(n)

    # Run microbenchmark
    bm <- microbenchmark(
      {{BENCHMARK_CODE}},
      times = 100,
      unit = "microseconds"
    )

    # Store results
    results[[paste0("n_", n)]] <- list(
      n = n,
      mean_us = mean(bm$time) / 1000,  # Convert nanoseconds to microseconds
      median_us = median(bm$time) / 1000,
      min_us = min(bm$time) / 1000,
      max_us = max(bm$time) / 1000,
      sd_us = sd(bm$time) / 1000,
      n_eval = nrow(bm)
    )

    cat(sprintf("  Mean: %.2f us, Median: %.2f us\n",
                results[[paste0("n_", n)]]$mean_us,
                results[[paste0("n_", n)]]$median_us))
  }

  results
}

# ============================================================================
# Run Benchmarks
# ============================================================================

cat("=== {{METHOD_NAME}} Benchmarks ===\n")
cat("R function: {{R_FUNCTION}}\n")
cat("Packages: {{R_PACKAGES}}\n\n")

results <- benchmark_{{METHOD_ID}}()

# ============================================================================
# Save Results
# ============================================================================

# Create results directory if needed
dir.create("results", showWarnings = FALSE)

# Save as CSV
df <- do.call(rbind, lapply(names(results), function(name) {
  r <- results[[name]]
  data.frame(
    method = "{{METHOD_ID}}",
    n = r$n,
    mean_us = r$mean_us,
    median_us = r$median_us,
    min_us = r$min_us,
    max_us = r$max_us,
    sd_us = r$sd_us,
    n_eval = r$n_eval,
    timestamp = Sys.time()
  )
}))

output_file <- sprintf("results/{{METHOD_ID}}_benchmark_%s.csv", format(Sys.Date(), "%Y%m%d"))
write.csv(df, output_file, row.names = FALSE)
cat(sprintf("\nResults saved to %s\n", output_file))

# Save as JSON for easier parsing
json_file <- sprintf("results/{{METHOD_ID}}_benchmark_%s.json", format(Sys.Date(), "%Y%m%d"))
write(toJSON(results, auto_unbox = TRUE, pretty = TRUE), json_file)
cat(sprintf("JSON results saved to %s\n", json_file))

# ============================================================================
# Print Summary Table
# ============================================================================

cat("\n=== Summary ===\n")
cat(sprintf("%-10s %15s %15s %15s\n", "n", "Mean (us)", "Median (us)", "SD (us)"))
cat(paste(rep("-", 60), collapse = ""), "\n")
for (name in names(results)) {
  r <- results[[name]]
  cat(sprintf("%-10d %15.2f %15.2f %15.2f\n", r$n, r$mean_us, r$median_us, r$sd_us))
}

# ============================================================================
# Template Variables (for generation)
# ============================================================================
# {{METHOD_NAME}} - Display name of the method (e.g., "Ordinary Least Squares")
# {{METHOD_ID}} - Short identifier (e.g., "ols")
# {{R_FUNCTION}} - R function being benchmarked (e.g., "lm()")
# {{R_PACKAGES}} - Comma-separated list of R packages
# {{EXTRA_PACKAGES}} - Additional packages to load (e.g., ', "sandwich"')
# {{DATA_GENERATION_CODE}} - R code to generate test data
# {{BENCHMARK_CODE}} - R code being benchmarked
# {{EXTRA_SIZES}} - Additional sample sizes (e.g., ", 100000")
